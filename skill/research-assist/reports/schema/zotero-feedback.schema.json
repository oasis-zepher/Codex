{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-research-assist.local/reports/schema/zotero-feedback.schema.json",
  "title": "Zotero Feedback Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "decisions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/decision"
      }
    }
  },
  "$defs": {
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "match",
        "decision",
        "rationale",
        "add_tags",
        "remove_tags",
        "add_collections",
        "remove_collections",
        "note_append"
      ],
      "properties": {
        "match": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "item_key": {
              "type": [
                "string",
                "null"
              ]
            },
            "doi": {
              "type": [
                "string",
                "null"
              ]
            },
            "title_contains": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "anyOf": [
            {
              "required": [
                "item_key"
              ]
            },
            {
              "required": [
                "doi"
              ]
            },
            {
              "required": [
                "title_contains"
              ]
            }
          ]
        },
        "decision": {
          "type": "string",
          "enum": [
            "archive",
            "watch",
            "read_first",
            "skim",
            "skip_for_now",
            "watchlist",
            "ignore",
            "unset"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "add_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remove_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "add_collections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remove_collections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note_append": {
          "type": "string"
        }
      }
    }
  }
}
