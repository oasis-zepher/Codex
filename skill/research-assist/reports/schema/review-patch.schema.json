{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-research-assist.local/reports/schema/review-patch.schema.json",
  "title": "Review Patch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "review"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_status",
        "reviewer_summary",
        "zotero_comparison",
        "recommendation",
        "why_it_matters",
        "quick_takeaways",
        "caveats",
        "generation"
      ],
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "system_generated",
            "agent_completed"
          ]
        },
        "reviewer_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "zotero_comparison": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "status",
            "summary",
            "related_items"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "not_run",
                "not_found",
                "matched",
                "uncertain"
              ]
            },
            "summary": {
              "type": "string"
            },
            "related_items": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "title",
                  "relation"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "item_key": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "relation": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "recommendation": {
          "type": "string",
          "enum": [
            "read_first",
            "skim",
            "watch",
            "skip_for_now",
            "archive",
            "watchlist",
            "ignore",
            "unset"
          ]
        },
        "why_it_matters": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_for_digest": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "quick_takeaways": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generation": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "mode",
            "sources"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "system_profile_only",
                "agent_zotero_fill"
              ]
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
